{
  "name": "commitlint-plugin-rai",
  "version": "0.1.7",
  "description": "Commitlint plugin for RAI footer validation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "sbom.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22 <27"
  },
  "scripts": {
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint . --fix",
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "commitlint",
    "plugin",
    "rai",
    "ai-attribution"
  ],
  "author": "Ashley Childress",
  "license": "LicenseRef-PolyForm-Shield-1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anchildress1/rai-lint.git",
    "directory": "packages/node-commitlint"
  },
  "bugs": {
    "url": "https://github.com/anchildress1/rai-lint/issues"
  },
  "homepage": "https://github.com/anchildress1/rai-lint#readme",
  "peerDependencies": {
    "@commitlint/lint": "^19.0.0 || ^20.0.0 || ^21.0.0",
    "@commitlint/types": "^19.0.0 || ^20.0.0 || ^21.0.0"
  },
  "peerDependenciesMeta": {
    "@commitlint/lint": {
      "optional": true
    },
    "@commitlint/types": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/lint": "^21.0.0",
    "@commitlint/types": "^21.0.1",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "volta": {
    "node": "24.11.1"
  }
}
